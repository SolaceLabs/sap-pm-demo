# ============================================================
# SAP PM Demo - Autonomous Maintenance Agent Configuration
# ============================================================
#
# HOW TO USE:
#   1. Copy this file to .env (in the same directory)
#   2. Fill in the real values
#   3. Never commit .env to Git — it's already in .gitignore
#
# ============================================================

# ── SAP Advanced Event Mesh (Solace) connection ──────────────
# Your Solace broker connection details
SOLACE_HOST=tcps://your-host.messaging.solace.cloud
SOLACE_VPN=your-vpn-name
SOLACE_USERNAME=your-solace-username
SOLACE_PASSWORD=your-solace-password
SOLACE_PORT=8883

# ── LLM API Configuration ────────────────────────────────────
# The agent uses an LLM for sensor data analysis and decision-making.
# Configure for your provider of choice.

# API_KEY: Your LLM provider API key
API_KEY=your-llm-api-key

# API_BASE: The LLM API endpoint
# For OpenAI:    https://api.openai.com/v1
# For Anthropic: https://api.anthropic.com/v1
# For Azure:     https://YOUR-RESOURCE.openai.azure.com/openai/deployments/YOUR-DEPLOYMENT
# For Ollama:    http://localhost:11434/v1
API_BASE=https://api.openai.com/v1

# LLM_MODEL: The model identifier
# OpenAI examples:    gpt-4, gpt-4-turbo, gpt-4o
# Anthropic examples: claude-3-5-sonnet-20241022, claude-3-opus-20240229
# Ollama examples:    llama3, mistral
LLM_MODEL=gpt-4

# ── MCP Server Configuration ─────────────────────────────────
# Path to the MCP server script (relative to where the agent runs)
MCP_SERVER_PATH=mcp_server/server.py

# ── Agent Behavior ───────────────────────────────────────────
# How often (seconds) the agent checks sensor readings
CHECK_INTERVAL=60
