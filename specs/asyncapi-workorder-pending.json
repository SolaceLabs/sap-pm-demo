              "type": "string",
              "minLength": 1
            },
            "source": { "type": "string" },
            "subject": { "type": "string" },
            "id": { "type": "string" },
            "time": {
              "type": "string",
              "format": "date-time"
            },
            "datacontenttype": {
              "description": "Describe the data encoding format",
              "type": "string",
              "const": "application/json"
            }
          },
          "required": ["id", "specversion", "source", "type"]
        }
      }
    }
  }
